# Variables de entorno — Zurullo World Cup 2026
# Copia este archivo como .env y rellena los valores

# === FIREBASE ===
VITE_FIREBASE_API_KEY=tu_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# === FOOTBALL-DATA.ORG API ===
# Registro gratuito en: https://www.football-data.org/client/register
VITE_FDO_API_KEY=tu_api_key_football_data_org
